# Supabase — obter em https://supabase.com/dashboard/project/<PROJECT_ID>/settings/api
SUPABASE_PROJECT_ID="<project_id>"
SUPABASE_URL="https://<project_id>.supabase.co"
SUPABASE_PUBLISHABLE_KEY="<anon_key>"
VITE_SUPABASE_PROJECT_ID="<project_id>"
VITE_SUPABASE_URL="https://<project_id>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<anon_key>"

# Service Role — apenas para scripts locais (seed, homologação). NUNCA usar no frontend.
SUPABASE_SERVICE_ROLE_KEY="<service_role_key>"

# Admin credentials (scripts locais)
ADMIN_EMAIL="admin@ebf2026.local"
ADMIN_PASSWORD="<admin_password>"

# Cloudflare Turnstile — obter em https://dash.cloudflare.com/?to=/:account/turnstile
VITE_TURNSTILE_SITE_KEY="<site_key>"
TURNSTILE_SECRET_KEY="<secret_key>"
