# Supabase Configuration
# Get these values from your Supabase project dashboard (Settings > API)

# Client-side variables (exposed to browser - must use VITE_ prefix)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key-here
VITE_SUPABASE_PROJECT_ID=your-project-id

# Server-side variables (not exposed to browser)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-public-key-here
SUPABASE_PROJECT_ID=your-project-id

# Server-only variables (for admin operations - KEEP SECRET)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Cloudflare Turnstile (CAPTCHA for inscription form)
# Get your keys at: https://dash.cloudflare.com/?to=/:account/turnstile
# Site key (public) - exposed to browser via VITE_ prefix
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
# Secret key (private) - server-side only, never exposed to browser
TURNSTILE_SECRET_KEY=your-turnstile-secret-key-here
# NOTE: The placeholder VITE_TURNSTILE_SITE_KEY above is Turnstile's "always passes"
# test key. Replace with your real site key for production.
